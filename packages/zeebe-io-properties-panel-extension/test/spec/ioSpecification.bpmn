<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ccon="http://ccon.camunda.io" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="ff9e015" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:process id="money_withdrawal_" name="Money withdrawal" isExecutable="true">
    <bpmn:documentation>When the process is completed successfully, the money can be picked up at the treasury office by the account user.</bpmn:documentation>
    <bpmn:extensionElements>
      <zeebe:versionTag value="1.35" />
    </bpmn:extensionElements>
    <bpmn:sequenceFlow id="Flow_02js93g" sourceRef="Activity_16hfey6" targetRef="Activity_1vyvs61" />
    <bpmn:sequenceFlow id="Flow_05fs7at" sourceRef="Gateway_1t1aeqq" targetRef="Activity_16hfey6" />
    <bpmn:sequenceFlow id="Flow_0jd00wr" sourceRef="Activity_1vyvs61" targetRef="Event_16qffma" />
    <bpmn:sequenceFlow id="Flow_0mu8nqe" sourceRef="start_from_slack" targetRef="Gateway_1t1aeqq" />
    <bpmn:sequenceFlow id="Flow_0yfx203" sourceRef="start_via_agent" targetRef="Gateway_1t1aeqq" />
    <bpmn:sequenceFlow id="Flow_1rgwbox" sourceRef="start_with_form" targetRef="Gateway_1t1aeqq" />
    <bpmn:exclusiveGateway id="Gateway_1t1aeqq">
      <bpmn:incoming>Flow_0mu8nqe</bpmn:incoming>
      <bpmn:incoming>Flow_0yfx203</bpmn:incoming>
      <bpmn:incoming>Flow_1rgwbox</bpmn:incoming>
      <bpmn:outgoing>Flow_05fs7at</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Activity_16hfey6" name="Lookup IBAN">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="test-1t1nx7q" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_05fs7at</bpmn:incoming>
      <bpmn:outgoing>Flow_02js93g</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="Event_16qffma" name="Money withdrawn">
      <bpmn:incoming>Flow_0jd00wr</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:startEvent id="start_via_agent" name="Start via agent" zeebe:modelerTemplate="io.camunda.mcp.start" zeebe:modelerTemplateVersion="1" zeebe:modelerTemplateIcon="data:image/png;base64,">
      <bpmn:extensionElements>
        <zeebe:properties>
          <zeebe:property name="io.camunda.tool:name" value="money_withdrawal" />
          <zeebe:property name="io.camunda.tool:purpose" value="Withdraw a specific amount of money for a user." />
          <zeebe:property name="io.camunda.tool:when_to_use" value="A user wants to have the treasury office withdraw money from their account, so they can pick it up." />
          <zeebe:property name="io.camunda.tool:when_not_to_use" value="A user wants to add money to their account. Use the &#39;money_deposit&#39; tool for that." />
          <zeebe:property name="io.camunda.tool:results" value="When the process is completed successfully, the money can be picked up at the treasury office by the account user. They need to bring valid identification.&#10; &#10;When the process is completed, you can find the IBAN number of the account the money was taken from in the &#39;iban&#39; variable. This can be used by the account user to double-check the money was withdrawn from the correct account." />
        </zeebe:properties>
        <zeebe:ioMapping>
          <zeebe:output source="=firstName + &#34; &#34; + lastName" target="userName" />
          <zeebe:output source="=amount" target="amount" />
        </zeebe:ioMapping>
        <ccon:ioSpecification>
          <ccon:inputSpecification name="firstName" description="The first name of the user to withdraw money for" type="string" required="true" schema="" />
          <ccon:inputSpecification name="lastName" description="The last name of the user to withdraw money for" type="string" required="true" schema="" />
          <ccon:inputSpecification name="amount" description="The amount of money to withdraw" type="int32" required="true" schema="" />
        </ccon:ioSpecification>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_0yfx203</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_0jzrny4" messageRef="Message_18nr92y" />
    </bpmn:startEvent>
    <bpmn:userTask id="Activity_1vyvs61" name="Withdraw money for user">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="Form_kchqurn" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_02js93g</bpmn:incoming>
      <bpmn:outgoing>Flow_0jd00wr</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:startEvent id="start_from_slack" name="Start from Slack" zeebe:modelerTemplate="io.camunda.connectors.inbound.Slack.MessageStartEvent.v1" zeebe:modelerTemplateVersion="7" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:properties>
          <zeebe:property name="inbound.type" value="io.camunda:slack-webhook:1" />
          <zeebe:property name="inbound.context" value="9b63973d-71dd-4afd-bd6d-e845597e3be5" />
          <zeebe:property name="inbound.slackSigningSecret" value="{{secrets.SLACK_KEY}}" />
          <zeebe:property name="inbound.verificationExpression" value="=if (body.type != null and body.type = &#34;url_verification&#34;) then {body:{&#34;challenge&#34;:body.challenge}, statusCode: 200} else null" />
          <zeebe:property name="consumeUnmatchedEvents" value="true" />
          <zeebe:property name="correlationRequired" value="notRequired" />
          <zeebe:property name="deduplicationModeManualFlag" value="false" />
          <zeebe:property name="deduplicationMode" value="AUTO" />
          <zeebe:property name="resultVariable" />
          <zeebe:property name="resultExpression" value="={&#10;  userName: request.body.userName,&#10;  amount: number(request.body.chat.message.text)&#10;}" />
        </zeebe:properties>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_0mu8nqe</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_12kp1lo" messageRef="Message_0ojl0ei" />
    </bpmn:startEvent>
    <bpmn:startEvent id="start_with_form" name="Start with form">
      <bpmn:extensionElements>
        <zeebe:formDefinition formId="do-things-05pggh2" />
        <zeebe:ioMapping>
          <zeebe:output source="=firstName + &#34; &#34; + lastName" target="userName" />
          <zeebe:output source="=amount" target="amount" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_1rgwbox</bpmn:outgoing>
    </bpmn:startEvent>
  </bpmn:process>
  <bpmn:message id="Message_18nr92y" name="dd58f9b0-647e-4902-a9d3-c87c3fc34b32" zeebe:modelerTemplate="io.camunda.mcp.start" />
